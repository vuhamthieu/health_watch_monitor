{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "make -j$(nproc)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make clean",
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Rebuild",
            "type": "shell",
            "command": "make clean && make -j$(nproc)",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Flash (ST-Link)",
            "type": "shell",
            "command": "make flash",
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "dependsOn": "Build"
        },
        {
            "label": "Erase Chip",
            "type": "shell",
            "command": "make erase",
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Size Report",
            "type": "shell",
            "command": "make size",
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "OpenOCD Server",
            "type": "shell",
            "command": "openocd -f interface/stlink.cfg -f target/stm32f1x.cfg",
            "isBackground": true,
            "group": "build",
            "problemMatcher": [
                {
                    "pattern": [{ "regexp": ".", "file": 1, "line": 2, "message": 3 }],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "Open On-Chip Debugger",
                        "endsPattern": "Listening on port"
                    }
                }
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
