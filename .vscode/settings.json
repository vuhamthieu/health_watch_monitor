{
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.associations": {
        "*.h": "c",
        "*.c": "c"
    },
    "C_Cpp.default.configurationProvider": "ms-vscode.makefile-tools",
    "files.exclude": {
        "**/.cproject": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.mxproject": true
    },
    "cortex-debug.openocdPath": "openocd",
    "cortex-debug.armToolchainPath": "/usr/bin"
}
