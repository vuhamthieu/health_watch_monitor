{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (OpenOCD + ST-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f1x.cfg"
            ],
            "executable": "${workspaceFolder}/build/health_watch_monitor.elf",
            "interface": "swd",
            "runToEntryPoint": "main",
            "preLaunchTask": "Build",
            "showDevDebugOutput": "none",
            "svdFile": "",
            "postLaunchCommands": [
                "monitor reset halt"
            ]
        },
        {
            "name": "Attach (OpenOCD + ST-Link)",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "openocd",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f1x.cfg"
            ],
            "executable": "${workspaceFolder}/build/health_watch_monitor.elf",
            "interface": "swd",
            "showDevDebugOutput": "none"
        }
    ]
}
